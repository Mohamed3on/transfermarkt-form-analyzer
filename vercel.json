{
  "regions": ["cdg1"],
  "installCommand": "bun install",
  "buildCommand": "bun run build",
  "functions": {
    "app/api/**/*.ts": {
      "maxDuration": 30
    },
    "app/api/cron/warm-cache/route.ts": {
      "maxDuration": 300
    }
  },
  "crons": [
    {
      "path": "/api/cron/warm-cache",
      "schedule": "0 6 * * *"
    }
  ]
}
